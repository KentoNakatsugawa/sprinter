# ══════════════════════════════════════════════════════════════════════════════
# Streamlit Cloud Secrets Configuration
# ══════════════════════════════════════════════════════════════════════════════
# 
# For local development: Copy this to .streamlit/secrets.toml
# For Streamlit Cloud: Add these in App Settings > Secrets
#
# ══════════════════════════════════════════════════════════════════════════════

# ── Authentication ────────────────────────────────────────────────────────────
# Simple password authentication (recommended for small teams)
APP_PASSWORD = "your-secure-password-here"

# ── Jira Cloud Configuration ─────────────────────────────────────────────────
JIRA_BASE_URL = "https://your-domain.atlassian.net"
JIRA_EMAIL = "your-email@example.com"
JIRA_API_TOKEN = "your-api-token-here"
JIRA_STORY_POINTS_FIELD = "customfield_10016"

# ── Google Gemini (Optional - for AI analysis) ───────────────────────────────
GEMINI_API_KEY = "your-gemini-api-key-here"

# ══════════════════════════════════════════════════════════════════════════════
# Advanced: Multi-user Authentication
# ══════════════════════════════════════════════════════════════════════════════
# Uncomment below to use username + password authentication
# Password hashes can be generated with:
#   python -c "import hashlib; print(hashlib.sha256('your-password'.encode()).hexdigest())"
#
# [users]
# admin = "5e884898da28047d9166e1..."  # password hash for "admin" 
# user1 = "8d969eef6ecad3c29a3a629..."  # password hash for "user1"
